# SarakEdge — Root gitignore

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/

# SQLite database (generated at runtime)
backend/telemetry.db

# Edge runtime artifacts
edge/buffer.json
edge/network_down.txt

# Next.js
frontend/.next/
frontend/node_modules/
frontend/.env.local
frontend/out/
frontend/.vercel/

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.vscode/
.idea/
*.suo
*.user

# Logs
*.log
npm-debug.log*
